# Local bot env — copy to .env.local and fill in
# DO NOT commit .env.local

# Binance Futures MAINNET API key (real money — be careful!)
# Optional if you only use testnet
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Binance Futures TESTNET API key (paper trading — recommended to start)
# Get these from https://testnet.binancefuture.com
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# false = mainnet (real money), true = testnet (paper trading)
# Recommended: start with true until you're comfortable
BINANCE_TESTNET=true

# Lovable Cloud DB (service role — keep secret!)
# Find SERVICE_ROLE_KEY in your Lovable Cloud → Backend → Project Settings → API
SUPABASE_URL=https://ntzqvfivvbwrdzyqurpx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Loop interval in ms (default 60s)
LOOP_INTERVAL_MS=60000
